# You should not need this file. `./install.sh` writes a .env for you, and
# everything else — community name, owner account, invite codes — is set up in
# the browser on first visit.
#
# It's here for people who'd rather do it by hand. Copy to `.env`.

# ── required ─────────────────────────────────────────────────────────────────

# Where your community lives. Must already resolve to this machine's public IP:
# Caddy proves ownership of it to Let's Encrypt to get a TLS certificate.
# A free dynamic-DNS name (DuckDNS etc.) works fine on a home connection.
CCCHAT_DOMAIN=chat.example.com

# Shared secret between the app and the voice server. Nobody ever types this —
# generate one and forget it:  openssl rand -hex 32
LIVEKIT_API_SECRET=

# ── optional ─────────────────────────────────────────────────────────────────

# The published image. Pin a version (…:v1.2.3) instead of latest if you'd
# rather upgrade deliberately.
#CCCHAT_IMAGE=ghcr.io/OWNER/ccchat:latest
#LIVEKIT_API_KEY=ccchat

# Skip the browser setup wizard and create the owner from the environment
# instead. Only for scripted installs; leave these empty otherwise.
#COMMUNITY_NAME=My Community
#OWNER_USERNAME=owner
#OWNER_PASSWORD=
# Lost the owner password? Set it above, set this to 1, start once, then unset.
#RESET_OWNER_PASSWORD=

# Point the browser at a LiveKit that is NOT behind our reverse proxy. Normally
# unset: the server derives wss://$CCCHAT_DOMAIN/livekit from the request itself.
# Needed for local dev, where there is no proxy:
#LIVEKIT_URL=ws://localhost:7880
