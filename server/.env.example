# Copy to .env and adjust. All values are optional.

# Port the HTTP + WebSocket server listens on.
PORT=8080

# Where the SQLite database is stored (Docker mounts this as a volume).
DATA_DIR=./data

# Shown in the client header.
COMMUNITY_NAME=My Community

# First-boot owner account. If OWNER_PASSWORD is empty, a random one is
# generated and printed to the console the first time you start the server.
OWNER_USERNAME=owner
OWNER_PASSWORD=

# Voice (LiveKit SFU). Keys must match livekit.yaml. LIVEKIT_URL is what the
# browser connects to (localhost in dev, your public host in production).
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_min_32_chars_long
